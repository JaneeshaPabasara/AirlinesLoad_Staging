      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update Fact Table"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{724C37D0-77B7-4BD8-B4C6-C3C1A127715E}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET&#xA;    f.accm_txn_complete_time = s.accm_txn_complete_time,&#xA;    f.txn_process_time_hours = &#xA;        CAST(&#xA;            DATEDIFF(MINUTE, f.accm_txn_create_time, s.accm_txn_complete_time)&#xA;            / 60.0&#xA;        AS DECIMAL(10,2))&#xA;FROM AirlinesDW.dbo.FactFlightSegments f&#xA;JOIN Airlines_Staging.dbo.StgTxnCompletions s&#xA;    ON f.fact_id = s.txn_id&#xA;WHERE f.accm_txn_create_time IS NOT NULL&#xA;  AND f.accm_txn_complete_time IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
