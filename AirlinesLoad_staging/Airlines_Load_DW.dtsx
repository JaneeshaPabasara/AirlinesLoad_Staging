    <DTS:Executable
      DTS:refId="Package\Populate DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{08716D49-84A6-4F1F-8318-E0E9167334AE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Populate DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B97725BF-6951-46A1-A01F-010D4FD37B66}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM DimDate)&#xA;&#xA;BEGIN&#xA;    &#xA;  DECLARE @start DATE = '2015-01-01', @end DATE = '2030-12-31';&#xA;    &#xA;  WHILE @start &lt;= @end&#xA;   &#xA;  BEGIN&#xA;       &#xA;     INSERT INTO DimDate&#xA;        &#xA;     SELECT&#xA;&#xA;            CONVERT(INT, FORMAT(@start, 'yyyyMMdd')),&#xA;                            @start,&#xA;&#xA;            YEAR(@start),&#xA;&#xA;            DATEPART(QUARTER, @start),&#xA;&#xA;            MONTH(@start),&#xA;&#xA;            DATENAME(MONTH, @start),&#xA;&#xA;            DATEPART(WEEK, @start),&#xA;&#xA;            DAY(@start),&#xA;&#xA;            DATENAME(WEEKDAY, @start),&#xA;&#xA;            CASE WHEN DATEPART(WEEKDAY, @start) IN (1,7)             THEN 1 ELSE 0 END;&#xA;&#xA;        SET @start = DATEADD(DAY, 1, @start);&#xA;&#xA;    END&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
