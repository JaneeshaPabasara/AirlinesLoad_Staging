    <DTS:Executable
      DTS:refId="Package\Load DimPassenger SCD2"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{68AB4450-4C0A-4D9D-8C3E-EE5071B5574D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimPassenger SCD2"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B97725BF-6951-46A1-A01F-010D4FD37B66}"
          SQLTask:SqlStatementSource="&#xA;IF OBJECT_ID('tempdb..#src') IS NOT NULL DROP TABLE #src;&#xA;&#xA;SELECT&#xA;    passenger_id,&#xA;    passenger_name,&#xA;    booking_count,&#xA;    CASE&#xA;        WHEN booking_count &gt;= 5 THEN 'Frequent Flyer'&#xA;        WHEN booking_count &gt;= 2 THEN 'Regular'&#xA;        ELSE 'Occasional'&#xA;    END AS travel_tier&#xA;INTO #src&#xA;FROM (&#xA;    SELECT&#xA;        passenger_id,&#xA;        passenger_name,&#xA;        COUNT(*) OVER (PARTITION BY passenger_id) AS booking_count&#xA;    FROM Airlines_Staging.dbo.StgTickets&#xA;) base&#xA;GROUP BY passenger_id, passenger_name, booking_count;&#xA;&#xA;&#xA;INSERT INTO DimPassenger&#xA;    (passenger_id, passenger_name, travel_tier,&#xA;     is_current, effective_date, expiry_date)&#xA;SELECT&#xA;    s.passenger_id,&#xA;    s.passenger_name,&#xA;    s.travel_tier,&#xA;    1,&#xA;    CAST(GETDATE() AS DATE),&#xA;    NULL&#xA;FROM #src s&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM DimPassenger d&#xA;    WHERE d.passenger_id = s.passenger_id&#xA;);&#xA;&#xA;&#xA;UPDATE d&#xA;SET&#xA;    d.is_current   = 0,&#xA;    d.expiry_date  = CAST(GETDATE() AS DATE)&#xA;FROM DimPassenger d&#xA;INNER JOIN #src s&#xA;    ON d.passenger_id = s.passenger_id&#xA;WHERE d.is_current = 1&#xA;  AND d.travel_tier &lt;&gt; s.travel_tier;&#xA;&#xA;&#xA;INSERT INTO DimPassenger&#xA;    (passenger_id, passenger_name, travel_tier,&#xA;     is_current, effective_date, expiry_date)&#xA;SELECT&#xA;    s.passenger_id,&#xA;    s.passenger_name,&#xA;    s.travel_tier,&#xA;    1,&#xA;    CAST(GETDATE() AS DATE),&#xA;    NULL&#xA;FROM #src s&#xA;INNER JOIN DimPassenger d&#xA;    ON s.passenger_id = d.passenger_id&#xA;WHERE d.is_current = 0&#xA;  AND d.expiry_date = CAST(GETDATE() AS DATE)&#xA;  AND NOT EXISTS (&#xA;      SELECT 1 FROM DimPassenger d2&#xA;      WHERE d2.passenger_id = s.passenger_id&#xA;        AND d2.is_current = 1&#xA;  );&#xA;&#xA;&#xA;UPDATE d&#xA;SET d.passenger_name = s.passenger_name&#xA;FROM DimPassenger d&#xA;INNER JOIN #src s&#xA;    ON d.passenger_id = s.passenger_id&#xA;WHERE d.is_current = 1&#xA;  AND d.passenger_name &lt;&gt; s.passenger_name;&#xA;&#xA;DROP TABLE #src;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
