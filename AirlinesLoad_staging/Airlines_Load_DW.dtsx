                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT fare_conditions,
      
  CASE fare_conditions
          
     WHEN 'Economy' THEN 1
         
     WHEN 'Comfort' THEN 2
          
     WHEN 'Business' THEN 3
            
     ELSE 99
      
  END AS fare_rank
   
FROM dbo.StgSeats</property>
